
@model Semester_project.Models.Admin

@{
    ViewBag.Title = "Admin Signup";
    //Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<style>
    body {
        background-color: #f8f9fa;
    }
</style>

<div class="container-fluid vh-100 d-flex p-0">
    <!-- Left image section -->
    <div class="d-none d-md-block col-md-6 p-0">
        <div style="height: 100%; background: url('/Content/images/logo.jpg') no-repeat center center; background-size: cover;  background-size: cover; margin-left:-110px;margin-top:-20px;"></div>
    </div>

    <!-- Right form section -->
    <div class="col-md-6 d-flex align-items-center justify-content-center" style="background-color: #f8f9fa;">
        <div class="p-4 shadow rounded bg-white" style="width: 100%; max-width: 400px; margin-left: 120px;">
            <h2 class="text-center mb-4">Admin Signup</h2>

            @using (Html.BeginForm("Signup", "Admin", FormMethod.Post))
            {
                <div class="mb-3">
                    @Html.LabelFor(m => m.Username)
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", placeholder = "Enter name", required = "required" })
                </div>

                <div class="mb-3">
                    @Html.LabelFor(m => m.Email)
                    @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "Enter email", type = "email", required = "required" })
                </div>

                <div class="mb-3">
                    <label for="Password">Password</label>
                    <input type="password" name="Password" id="Password" class="form-control" placeholder="Enter password" required />
                </div>

                <div class="mb-3">
                    <label for="ConfirmPassword">Confirm Password</label>
                    <input type="password" name="ConfirmPassword" id="ConfirmPassword" class="form-control" placeholder="Re-enter password" required />
                </div>

                <button type="submit" class="btn btn-primary w-100">Sign Up</button>
            }

            <div class="mt-3 text-center">
                <a href="@Url.Action("Login", "Admin")" style="text-decoration: none; color: inherit; ">Already have an account? Log in</a>
            </div>
        </div>
    </div>
</div>
