
@{
    ViewBag.Title = "Dashboard";
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
        }

        .main-header {
            padding: 20px 30px;
            border-bottom: 1px solid #ddd;
            font-size: 20px;
            background-color: skyblue;
        }

        .layout-container {
            display: flex;
            height: calc(100vh - 70px); /* Adjust for header height */
        }

        .sidebar {
            width: 250px;
            background-color: skyblue;
            padding: 20px;
            border-right: 1px solid #ddd;
        }

            .sidebar a {
                display: block;
                padding: 10px 15px;
                color: black;
                text-decoration: none;
                border-radius: 5px;
                margin-bottom: 10px;
            }

                .sidebar a:hover {
                    background-color: #e0e0e0;
                }

        .main-content {
            flex-grow: 1;
            padding: 30px;
            overflow-y: auto;
        }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="main-header">
        <h2>Attendance Management System</h2>
    </div>

    <!-- Sidebar + Main Content -->
    <div class="layout-container">
        <!-- Sidebar -->
        <div class="sidebar">
            @Html.ActionLink("Students", "Student", "Attendence")
            @Html.ActionLink("Departments", "Department", "Department")
            @Html.ActionLink("Courses", "Course", "Course")
            @Html.ActionLink("Enrollments", "Enrollment", "Enrollment")
            @Html.ActionLink("Charts", "Chart", "Chart")
          
        </div>

        <!-- Page Content -->
        <div class="main-content">
            @RenderBody()
        </div>
    </div>
    
</body>
</html>
