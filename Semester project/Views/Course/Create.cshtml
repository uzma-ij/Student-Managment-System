@model Semester_project.Models.Course
@{
    ViewBag.Title = "Create";
}

<h2>Add new Course</h2>

<style>
    .btn {
        margin-top: 20px;
    }
</style>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <div class="form-group">
        @Html.LabelFor(model => model.CourseName)
        @Html.TextBoxFor(model => model.CourseName, new { @class = "form-control" })
    </div>

    <div class="form-group">
        @Html.LabelFor(model => model.CreditHours)
        @Html.TextBoxFor(model => model.CreditHours, new { @class = "form-control" })
    </div>
    
    <div class="form-group">
        @Html.LabelFor(model => model.DepartmentId, "Department")
        @Html.DropDownListFor(model => model.DepartmentId, (SelectList)ViewBag.Departments, "Select Department", new { @class = "form-control" })
    </div>

    <button type="submit" class="btn btn-success">Save</button>
</div>
}
