@model List<Semester_project.Models.Course>

@{
    ViewBag.Title = "Course";
    Layout = "~/Views/Shared/Layout.cshtml";
}

<style>
    .headings {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .btn {
        height: 35px;
    }
</style>
<div class="headings">

    <h2>Courses</h2>
    <a href="/Course/Create" class="btn btn-primary">Add new Course</a>

</div>

<table class="table table-bordered table-hover">
    <tr>
        <th>Id</th>
        <th>Course Name</th>
        <th>Credit Hours</th>
       <th>Department Name</th>
        <th>Actions</th>
    </tr>
    @foreach (var course in Model)
    {
        <tr>
            <td>@course.CourseId</td>
            <td>@course.CourseName</td>
            <td>@course.CreditHours</td>
            <td>@course.Department.DepartmentName</td>
        
            <td style="width: 150px;">
                <a href="@Url.Action("Edit", "Course", new { id = course.CourseId })" class="btn btn-success btn-sm">Edit</a>


                <form action="@Url.Action("Delete", "Course")" method="post" style="display:inline;">
                    <input type="hidden" name="id" value="@course.CourseId" />
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this course?');">Delete</button>
                </form>
            </td>
        </tr>
    }
</table>
