@{
    ViewBag.Title = "Dashboard";
    Layout = null; 
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewBag.Title</title>
   
    <style>
        body {
            margin: 0;
            overflow: hidden;
        }

        .sidebar {
            height: 100vh;
            background-color: skyblue;
            padding: 20px;
            border-right: 1px solid #ddd;
        }

            .sidebar a {
                display: block;
                padding: 10px 15px;
                color: black;
                text-decoration: none;
                border-radius: 5px;
                margin-bottom: 10px;
            }

                .sidebar a:hover {
                    background-color: #e0e0e0;
                }

        .main-header {
            padding: 20px 30px;
            border-bottom: 1px solid #ddd;
            font-size:20px;
            background-color:skyblue;
        }

        .main-content {
            padding: 30px;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar -->
        <div class="main-header">
            <h2>Attendance Management System</h2>
            
        </div>
        
        <div class="sidebar" style="width: 250px;">

            @Html.ActionLink("Students", "Student")
            @Html.ActionLink("Departments", "Department", "Department")
            @Html.ActionLink("Courses", "Course", "Course")
            @Html.ActionLink("Enrollments", "Enrollment", "Enrollment")
            @Html.ActionLink("Enrollments", "Enrollment", "Enrollment")
        </div>

        
    </div>
</body>
</html>
