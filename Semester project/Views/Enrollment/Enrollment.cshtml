@model List<Semester_project.Models.Enrollment>
@{
    ViewBag.Title = "Enrollment";
    Layout = "~/Views/Shared/Layout.cshtml";
}

<style>
    .headings {
        display: flex;
        justify-content: space-between;
        margin-bottom: 10px;
    }

    .btn {
        height: 35px;
    }
</style>
<div class="headings">

    <h2>Enrollements</h2>
    <a href="/Enrollment/Create" class="btn btn-primary">Add new Enrollement</a>

</div>

<table class="table table-bordered table-hover">
    <tr>
        <th>Id</th>
        <th>Student Name</th>
        <th>Course Name</th>
        <th>Enrollement Date</th>
        <th>Actions</th>
    </tr>
    @foreach (var enrollment in Model)
    {
        <tr>
            <td>@enrollment.EnrollmentId</td>
            <td>@enrollment.Student.FullName</td>
            <td>@enrollment.Course.CourseName</td>
            
            <td>@(enrollment.EnrollmentDate?.ToString("yyyy-MM-dd"))</td>
      
            <td style="width: 150px;">
                <a href="@Url.Action("Edit", "Enrollment", new { id = enrollment.EnrollmentId })" class="btn btn-success btn-sm">Edit</a>

      
                <form action="@Url.Action("Delete", "Enrollment")" method="post" style="display:inline;">
                    <input type="hidden" name="id" value="@enrollment.EnrollmentId" />
                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this Enrollment?');">Delete</button>
                </form>
            </td>
        </tr>
    }
</table>
